<Page x:Class="No_Mole.Components.CameraNotFoundWarning"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:No_Mole.Components"
      mc:Ignorable="d" 
      d:DesignHeight="400" d:DesignWidth="400"
      Title="CameraNotFoundWarning">

    <Grid>
        <Border Background="#333333" CornerRadius="20" Padding="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10" >

                <!-- Warning Icon -->
                <Image Source="/Resources/Icons/redicon.png" Width="104" Height="105" HorizontalAlignment="Center" />

                <!-- Main Text -->
                <TextBlock Text="No Device is connected" FontSize="16" FontWeight="Bold" 
                           Foreground="White" TextAlignment="Center" Margin="0,10,0,0" />

                <!-- Subtext -->
                <TextBlock Text="Please connect the device to your computer" 
                           FontSize="12" Foreground="Gray" TextAlignment="Center" Margin="0,5,0,10" />

                <!-- Retry Button -->
                <Button Content="Retry" Width="100" HorizontalAlignment="Center" Background="#ad42ad" Foreground="White" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
